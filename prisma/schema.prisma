generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  VIEWER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  avatar    String?
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersCreated Order[] @relation("OrderCreatedBy")

  @@map("users")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  brand       String?
  category    String?
  sku         String   @unique
  jpyCost     Decimal  @db.Decimal(10, 2)
  thbPrice    Decimal  @db.Decimal(10, 2)
  otherShopPrice Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  salesCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  customerName  String
  customerEmail String?
  customerPhone String?
  status        OrderStatus @default(PENDING)
  notes         String?

  totalJpyCost   Decimal @db.Decimal(12, 2)
  totalJpyPrice  Decimal @db.Decimal(12, 2)
  totalProfitJpy Decimal @db.Decimal(12, 2)

  totalThbCost   Decimal @db.Decimal(12, 2)
  totalThbPrice  Decimal @db.Decimal(12, 2)
  totalProfitThb Decimal @db.Decimal(12, 2)

  exchangeRateId String?
  exchangeRate   ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  createdById String
  createdBy   User   @relation("OrderCreatedBy", fields: [createdById], references: [id])

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int

  unitJpyCost   Decimal @db.Decimal(10, 2)
  unitJpyPrice  Decimal @db.Decimal(10, 2)
  totalJpyCost  Decimal @db.Decimal(12, 2)
  totalJpyPrice Decimal @db.Decimal(12, 2)
  profitJpy     Decimal @db.Decimal(12, 2)

  unitThbCost   Decimal @db.Decimal(10, 2)
  unitThbPrice  Decimal @db.Decimal(10, 2)
  totalThbCost  Decimal @db.Decimal(12, 2)
  totalThbPrice Decimal @db.Decimal(12, 2)
  profitThb     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("order_items")
}

model ExchangeRate {
  id        String   @id @default(uuid())
  jpyToThb  Decimal  @db.Decimal(8, 6)
  source    String   @default("API")
  createdAt DateTime @default(now())

  orders Order[]

  @@map("exchange_rates")
}
